
# -------------------------------------------------------------
# MODE D'EXÉCUTION
# -------------------------------------------------------------
# false → mode local : la pipeline utilise data/raw/ existants.
#         Aucune connexion GCP requise. Recommandé pour les membres
#         qui n'ont pas accès à BigQuery.
# true  → mode BigQuery : extract.py lance les requêtes SQL et
#         réécrit data/raw/. Nécessite GOOGLE_APPLICATION_CREDENTIALS.
USE_BIGQUERY=false


# -------------------------------------------------------------
# PARAMÈTRES BIGQUERY (ignorés si USE_BIGQUERY=false)
# -------------------------------------------------------------

# Google Cloud Project ID et Table ID
GOOGLE_CLOUD_PROJECT=project-id
BQ_TABLE=table-id


# Nombre max de lignes par requête (quota BigQuery : 1 TB/mois gratuit).
BQ_LIMIT=10000


# -------------------------------------------------------------
# FILTRES GDELT — pays cible
# -------------------------------------------------------------
COUNTRY_CODE_ACTION=BN    # ActionGeo_CountryCode du Bénin
COUNTRY_CODE_ACTOR=BEN    # Actor1CountryCode du Bénin


# -------------------------------------------------------------
# PÉRIODE D'ANALYSE
# -------------------------------------------------------------
YEAR_START=2025
DATE_START=20250101    # Format YYYYMMDD — début de la fenêtre
DATE_END=20260428      # Format YYYYMMDD — fin de la fenêtre


# -------------------------------------------------------------
# CHEMINS — DONNÉES BRUTES (data/raw/)
# Ne modifier que si vous changez la structure de répertoires.
# -------------------------------------------------------------
DATA_RAW_PATH=data/raw/gdelt_benin_main.csv
DATA_RAW_GEO_PATH=data/raw/geo_events.csv


# -------------------------------------------------------------
# CHEMINS — DONNÉES TRAITÉES (data/processed/)
# Tous ces fichiers sont générés par transform.py + load.py.
# -------------------------------------------------------------
DATA_CLEAN_PATH=data/processed/gdelt_benin_clean.csv
DATA_TONE_PATH=data/processed/tone_monthly.csv
DATA_ACTORS_PATH=data/processed/actors_country.csv
DATA_EVENTS_PATH=data/processed/events_by_type.csv
DATA_GEO_PATH=data/processed/geo_events.csv

# Zooms événements clés
DATA_ZOOM_DEC2025_PATH=data/processed/zoom_dec2025.csv
DATA_ZOOM_ELECTION_PATH=data/processed/zoom_election2026.csv

# Datasets thématiques
DATA_CULTURE_PATH=data/processed/culture_tourisme.csv
DATA_COOPERATION_NGA_PATH=data/processed/cooperation_ben_nga.csv
DATA_SECURITE_NORD_PATH=data/processed/securite_nord.csv
DATA_FEMMES_PATH=data/processed/femmes_benin.csv
DATA_CHINE_PATH=data/processed/chine_benin.csv
DATA_PERSO_BENIN_PATH=data/processed/personnalites_benin.csv
DATA_PERSO_ETRANGERES_PATH=data/processed/personnalites_etrangeres.csv
DATA_LIBERTE_PRESSE_PATH=data/processed/liberte_presse.csv
DATA_CAN2025_PATH=data/processed/can2025_sport.csv
DATA_ECONOMIE_PATH=data/processed/economie.csv
DATA_SOURCES_OFF_PATH=data/processed/sources_officielles.csv
DATA_MEDIAS_BENINOIS_PATH=data/processed/medias_beninois.csv
DATA_MEDIAS_INTERNATIONAUX_PATH=data/processed/medias_internationaux.csv